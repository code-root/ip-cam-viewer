# نسخ إلى .env على جهاز الشركة (Windows)
# copy .env.company-edge.example .env

HOST=0.0.0.0
PORT=3000
SERVE_CLIENT=true
# يُحدَّث تلقائياً عند التشغيل عبر start-company-edge.bat — أو ضع IP الجهاز يدوياً
CLIENT_URL=http://192.168.1.7:3000

SITE_NAME=IP Camera Viewer - Company

JWT_SECRET=CHANGE-ME-32-CHARS-MINIMUM-SECRET!!
JWT_REFRESH_SECRET=CHANGE-ME-REFRESH-SECRET-32CHARS
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

GO2RTC_BIN=./bin/go2rtc.exe
GO2RTC_API=http://127.0.0.1:1984
GO2RTC_CONFIG=./config/go2rtc.yaml

DATABASE_URL=file:./server/data/app.db
RECORDINGS_PATH=./data/recordings
SNAPSHOTS_PATH=./data/snapshots
FACES_PATH=./data/faces

PYTHON_BIN=.venv\Scripts\python.exe
FACE_SCAN_ENABLED=true
FACE_SCAN_INTERVAL_SEC=1
FACE_ANALYSIS_MODE=people_only
FACE_FURNITURE_FILTER=true

MAX_CONCURRENT_STREAMS=8

# —— وكيل الكاميرات (CompanyEdgeLauncher.exe) ——
# بعد تشغيل السيرفر: اكتشاف ONVIF، تسجيل دخول، ربط البث عبر API
EDGE_AUTO_DISCOVER=true
EDGE_AUTO_PROVISION=true
EDGE_API_USERNAME=admin
EDGE_API_PASSWORD=admin123
EDGE_CAMERA_USERNAME=admin
# كلمة واحدة أو عدة كلمات: admin123,admin123456
EDGE_CAMERA_PASSWORD=admin123
# EDGE_CAMERA_PASSWORDS=admin123,admin123456,
EDGE_DISCOVER_TIMEOUT_MS=12000
