PORT=3000
HOST=0.0.0.0
CLIENT_URL=http://localhost:5173
JWT_SECRET=dev-jwt-secret-change-in-production-32chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
# macOS/Linux: ./bin/go2rtc  |  Windows: ./bin/go2rtc.exe
GO2RTC_BIN=./bin/go2rtc
GO2RTC_API=http://127.0.0.1:1984
GO2RTC_CONFIG=./config/go2rtc.yaml
RECORDINGS_PATH=./data/recordings
SNAPSHOTS_PATH=./data/snapshots
MAX_CONCURRENT_STREAMS=8
IDLE_TIMEOUT_MINUTES=30
SITE_NAME=IP Camera Viewer
DATABASE_URL=file:server/data/app.db
FACES_PATH=./data/faces
FACE_SCAN_INTERVAL_SEC=3
FACE_DETECT_TIMEOUT_SEC=90
FACE_SCAN_MAX_BACKOFF_SEC=20
FACE_MATCH_THRESHOLD=0.55
FACE_MATCH_THRESHOLD_CCTV=0.62
FACE_MIN_LIVE_CONFIDENCE=0.45
FACE_MIN_DETECTION_SCORE=0.22
FACE_CONFIRM_SCANS=1
FACE_MATCH_MARGIN=0.07
FACE_AUTO_ENROLL_UNKNOWN=true
FACE_TRACK_MATCH_THRESHOLD=0.48
FACE_AUTO_ENROLL_MATCH_THRESHOLD=0.5
FACE_TRACK_ENROLL_MIN_HITS=4
FACE_DETECT_UPSAMPLES=0,1
FACE_STRICT_LANDMARKS=false
FACE_CNN_IF_FEWER_THAN=2
FACE_SCAN_QUALITY=sub
FACE_PERSON_DETECT=true
FACE_SHOW_PERSON_BOXES=false
FACE_YOLO_CONF=0.32
FACE_MEDIAPIPE_CONF=0.35
FACE_MODELS_DIR=./server/models
FACE_ABSENCE_CLOSE_SEC=180
# FACE_SCAN_ENABLED=false
# macOS/Linux: ./.venv/bin/python3  |  Windows: .venv\Scripts\python.exe
PYTHON_BIN=./.venv/bin/python3
FACE_SCAN_ENABLED=true
